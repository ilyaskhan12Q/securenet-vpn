# ---------------------------------------------------------------------------
# SecureNet VPN — Environment Variables
# Copy this file to .env and fill in the values.
# The .env file MUST NOT be committed to version control.
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_PASSWORD=changeme_use_a_strong_random_password
DATABASE_URL=postgres://securenet:${POSTGRES_PASSWORD}@localhost:5432/securenet

# JWT signing secret — minimum 64 random bytes, hex-encoded.
# Generate with:  openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING

# Grafana admin password (docker-compose only)
GRAFANA_PASSWORD=changeme
GRAFANA_DOMAIN=localhost

# Log level override
RUST_LOG=info,securenet_core=debug

# Server WireGuard listen address
SECURENET_LISTEN_ADDR=0.0.0.0:51820

# API bind address
SECURENET_API_BIND=127.0.0.1:8080

# Config file path (used by both binaries)
SECURENET_CONFIG=/etc/securenet/server.toml

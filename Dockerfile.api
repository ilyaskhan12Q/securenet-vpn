# ---------------------------------------------------------------------------
# Stage 1: Builder
# ---------------------------------------------------------------------------
FROM rust:slim-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    libc6-dev  \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release -p securenet-api

# ---------------------------------------------------------------------------
# Stage 2: Runtime image
# ---------------------------------------------------------------------------
FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl            \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -r -s /bin/false -u 1001 securenet

COPY --from=builder /build/target/release/securenet-api /usr/local/bin/securenet-api
COPY --from=builder /build/crates/securenet-api/migrations /migrations

RUN chmod +x /usr/local/bin/securenet-api

USER securenet

EXPOSE 8080

ENTRYPOINT ["securenet-api"]
CMD ["--config", "/etc/securenet/server.toml"]